# Copy to cg.env and adjust for your machine. Sourced by ./cg.
#
# Production: if the official `codegraph` is on PATH, leave this empty — the
# wrapper uses it directly (self-contained bundled runtime, no Node needed).
#
# Dev / source mode: run the built dist with a Node >= 22.5 runner.
# CODEGRAPH_DIST="/abs/path/to/codegraph/dist/bin/codegraph.js"
# CODEGRAPH_NODE="npx -y node@22"   # or a node22 binary on PATH
#
# CG_PROJECT defaults to the current directory (the repo being analyzed).
