#!/usr/bin/env bash
# wiki-ingest-cheap — DeepSeek 无头摄取 wrapper（ADR-002 §4）。
#
# 用法：wiki-ingest-cheap "<提示词>" [claude -p 额外参数...]
#   例：wiki-ingest-cheap "$(cat batch-prompt.txt)" --output-format json --max-turns 100
#
# 环境变量：
#   DEEPSEEK_API_KEY          必填。env 缺失时从组件根 wiki-ingest.env 加载（gitignored
#                             本地 env · 一次写入长期复用 · 模板 wiki-ingest.env.example）。
#                             key 只进进程环境，不写进被追踪/日志的文件（gitignored env 除外）。
#   WIKI_ENGINE_INGEST_MODEL  摄取档模型，默认 deepseek-v4-flash
#                             （选型见 docs/benchmark-pro-vs-flash.md：flash 真实账单
#                              便宜 ~2.4×、问答质量与 pro 持平；代价是偶发纪律漂移，
#                              靠 wiki-lint 门禁兜底。无人值守零返工可设 deepseek-v4-pro。）
#   WIKI_ENGINE_FAST_MODEL    小快任务档，默认 deepseek-v4-flash
#   WIKI_ENGINE_CLAUDE_BIN    claude 可执行文件，默认 claude（离线测试注入 mock 用）
#
# 要点：
# - 按调用切换，不动全局：环境变量只活在本进程内。
# - 显式钉死模型，防止兼容层把未识别名静默映射到最低档（研究归档 §6）。
# - 工具面收窄：只给读 + 写 + 两个白名单脚本，不给网络、不给任意 Bash。
#   白名单只放行直接执行脚本路径——提示词里要写明"勿加 python3 前缀"。
#
# 退出码：2 参数/环境缺失；其余透传 claude 退出码（0 即成功）。
set -euo pipefail

# 脚本自身 bin 目录的绝对路径（plugin-ready：不假定组件落在仓库根固定深度）。
# 用于：① --allowedTools 两个 Bash 放行前缀按实际脚本位置生成；
#       ② prompt 顶部同源注入摄取会话的权威调用路径（与放行前缀逐字同源）。
BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  echo "usage: wiki-ingest-cheap \"<prompt>\" [extra claude args...]" >&2
  echo "       requires DEEPSEEK_API_KEY in the environment" >&2
}

if [ "$#" -lt 1 ] || [ -z "$1" ]; then
  usage
  exit 2
fi
if [ "${1}" = "-h" ] || [ "${1}" = "--help" ]; then
  usage
  exit 0
fi
# key 文件化（feat-wiki-auto-ingest-b2 · U2）：env 无 DEEPSEEK_API_KEY 时，从组件根的本地
# gitignored env 文件加载（一次写入长期复用；模板 wiki-ingest.env.example）。脚本有 set -e，
# 先 [ -f ] 判存在再 source，防不存在文件时 source 崩溃（对齐 spec T3 / reviewer v2 INFO②）。
WIKI_INGEST_ENV_FILE="$(dirname "$BIN_DIR")/wiki-ingest.env"
if [ -z "${DEEPSEEK_API_KEY:-}" ] && [ -f "$WIKI_INGEST_ENV_FILE" ]; then
  # shellcheck disable=SC1090
  . "$WIKI_INGEST_ENV_FILE"
fi
if [ -z "${DEEPSEEK_API_KEY:-}" ]; then
  echo "wiki-ingest-cheap: DEEPSEEK_API_KEY 未设置（可写入本地 gitignored ${WIKI_INGEST_ENV_FILE##*/}；key 不写进被追踪/日志的文件）" >&2
  exit 2
fi

prompt="$1"
shift

# 同源注入（决议 A · LOW-1/LOW-2）：把 wiki-lint / wiki-rescan 的"解析后字面绝对
# 路径"声明为权威调用路径，置于 prompt 顶部，压过 SKILL.md / 批量 prompt 里任何相对
# 调用指引，保证"放行前缀"与"摄取会话实际调用路径"逐字同源（化解 R1 张力）。
# 注入的是 $BIN_DIR 展开后的字面绝对路径，非变量名串。
prompt="【权威调用路径 · 覆盖任何相对路径指引】
本会话执行 wiki-lint / wiki-rescan 时，必须用以下绝对路径（勿用相对路径、勿加 python3 前缀）：
  wiki-lint   : ${BIN_DIR}/wiki-lint
  wiki-rescan : ${BIN_DIR}/wiki-rescan

${prompt}"

export ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"
export ANTHROPIC_AUTH_TOKEN="$DEEPSEEK_API_KEY"
unset ANTHROPIC_API_KEY 2>/dev/null || true
ingest_model="${WIKI_ENGINE_INGEST_MODEL:-deepseek-v4-flash}"
fast_model="${WIKI_ENGINE_FAST_MODEL:-deepseek-v4-flash}"
export ANTHROPIC_MODEL="$ingest_model"
export ANTHROPIC_DEFAULT_SONNET_MODEL="$ingest_model"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="$fast_model"
export ANTHROPIC_SMALL_FAST_MODEL="$fast_model"

exec "${WIKI_ENGINE_CLAUDE_BIN:-claude}" -p "$prompt" \
  --allowedTools "Read,Glob,Grep,Write,Edit,Bash(${BIN_DIR}/wiki-lint:*),Bash(${BIN_DIR}/wiki-rescan:*)" \
  "$@"
